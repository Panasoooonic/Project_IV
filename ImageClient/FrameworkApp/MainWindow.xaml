<Window x:Class="ImageClient.FrameworkApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Image Transfer Client"
        Height="400" Width="400"
        Background="#F5F7FA">

        <!-- TextBox structures -->
        <Window.Resources>
            <Style TargetType="TextBox">
                <Setter Property="Height" Value="35"/>
                <Setter Property="FontSize" Value="18"/>
                <Setter Property="Padding" Value="8,4"/>
                <Setter Property="Margin" Value="0,5,0,12"/>
                <Setter Property="BorderBrush" Value="#CCCCCC"/>
                <Setter Property="BorderThickness" Value="1"/>
            </Style>

            <Style TargetType="PasswordBox">
                <Setter Property="Height" Value="35"/>
                <Setter Property="FontSize" Value="18"/>
                <Setter Property="Padding" Value="8,4"/>
                <Setter Property="Margin" Value="0,5,0,15"/>
                <Setter Property="BorderBrush" Value="#CCCCCC"/>
                <Setter Property="BorderThickness" Value="1"/>
            </Style>
        </Window.Resources>



    <Grid>

        <!-- LOGIN SCREEN -->
        <Border x:Name="LoginPanel"
                Width="300"
                Padding="25"
                Background="White"
                CornerRadius="10"
                VerticalAlignment="Center"
                HorizontalAlignment="Center"
                Visibility="Visible">

            <StackPanel>
                <TextBlock Text="Image Client Login"
                           FontSize="20"
                           FontWeight="Bold"
                           Margin="0,0,0,15"
                           HorizontalAlignment="Center"/>

                <TextBox x:Name="UsernameBox"/>
                <PasswordBox x:Name="PasswordBox"/>     

                <Button x:Name="LoginButton"
                        Content="Login"
                        Height="35"
                        Background="#4A90E2"
                        Foreground="White"
                        FontWeight="Bold"
                        Click="Login_Click"/>

                <TextBlock x:Name="LoginStatus"
                           Foreground="Red"
                           Margin="0,10,0,0"
                           TextAlignment="Center"/>

            </StackPanel>
        </Border>


        <!-- Main screen -->
        <StackPanel x:Name="MainPanel"
            Visibility="Collapsed"
            VerticalAlignment="Center"
            HorizontalAlignment="Center"
            Width="300">

            <!-- Ttle -->
            <TextBlock Text="Image Transfer"
                    FontSize="20"
                    FontWeight="Bold"
                    Margin="0,0,0,15"
                    HorizontalAlignment="Center"/>

            <!-- Status -->
            <Border Background="#EEF2F7"
                    CornerRadius="5"
                    Padding="10"
                    Margin="0,0,0,15">

                <TextBlock x:Name="StatusText"
                        Text="Ready"
                        TextAlignment="Center"/>
            </Border>

            <!-- Request Image Buttton -->
            <Button x:Name="RequestButton"
                    Content="Download Image"
                    Height="35"
                    Background="#4A90E2"
                    Foreground="White"
                    FontWeight="Bold"
                    Click="RequestImage_Click"/>

            <!-- Progress -->
            <StackPanel Margin="0,15,0,0">

                <TextBlock Text="Download Progress"
                        FontSize="12"
                        Margin="0,0,0,5"/>

                <ProgressBar x:Name="ProgressBar"
                            Height="20"
                            Minimum="0"
                            Maximum="100"/>

            </StackPanel>

            <!-- Save Location -->
            <StackPanel Margin="0,15,0,0">
                <TextBlock Text="Save Location"
                        FontSize="12"/>

                <DockPanel Margin="0,5,0,0">

                    <TextBox x:Name="SavePathBox"
                            IsReadOnly="True"
                            Width="200"
                            Margin="0,0,5,0"/>

                  
                </DockPanel>
            </StackPanel>

            <!-- Logout -->
            <Button Content="Logout"
                    Margin="0,20,0,0"
                    Height="30"
                    Background="#E74C3C"
                    Foreground="White"
                    Click="Logout_Click"/>

        </StackPanel>


    </Grid>
</Window>