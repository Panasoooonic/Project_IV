<Window x:Class="FrameworkApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Secure Image Download Client"
        Height="560"
        Width="900"
        Background="#F5F7FA">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Background="White" CornerRadius="10" Padding="20" Margin="0,0,0,15">
            <StackPanel>
                <TextBlock Text="Secure Image Download Client" FontSize="22" FontWeight="Bold"/>
                <TextBlock Text="Login, request image, receive packets, save locally"
                           Margin="0,6,0,0"
                           Foreground="#666666"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Background="White" CornerRadius="10" Padding="20" Margin="0,0,0,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Username:" VerticalAlignment="Center"/>
                <TextBox x:Name="UsernameTextBox" Grid.Column="1" Margin="10,0,15,10" Text="trent"/>

                <TextBlock Text="Password:" Grid.Column="2" VerticalAlignment="Center"/>
                <PasswordBox x:Name="PasswordBox" Grid.Column="3" Margin="10,0,0,10"/>

                <TextBlock Text="Image File:" Grid.Row="1" VerticalAlignment="Center"/>
                <TextBox x:Name="ImageFileTextBox" Grid.Row="1" Grid.Column="1" Margin="10,0,15,0" Text="sample.jpg"/>

                <Button x:Name="LoginButton"
                        Grid.Row="1"
                        Grid.Column="2"
                        Content="Login"
                        Width="100"
                        Height="32"
                        Margin="0,0,10,0"
                        Click="LoginButton_Click"/>

                <Button x:Name="RequestImageButton"
                        Grid.Row="1"
                        Grid.Column="3"
                        Content="Request Image"
                        Width="130"
                        Height="32"
                        HorizontalAlignment="Left"
                        IsEnabled="False"
                        Click="RequestImageButton_Click"/>
            </Grid>
        </Border>

        <Border Grid.Row="2" Background="White" CornerRadius="10" Padding="20" Margin="0,0,0,15">
            <StackPanel>
                <TextBlock Text="Transfer Progress" FontWeight="Bold" Margin="0,0,0,10"/>
                <ProgressBar x:Name="TransferProgressBar" Height="22" Minimum="0" Maximum="100"/>
                <TextBlock x:Name="StatusTextBlock" Margin="0,10,0,0" Text="Not connected."/>
            </StackPanel>
        </Border>

        <Border Grid.Row="3" Background="White" CornerRadius="10" Padding="15">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Client Log" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>

                <TextBox x:Name="LogTextBox"
                         Grid.Row="1"
                         IsReadOnly="True"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         TextWrapping="Wrap"
                         FontFamily="Consolas"
                         FontSize="13"/>
            </Grid>
        </Border>
    </Grid>
</Window>